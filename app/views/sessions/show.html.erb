<main class="shell game-shell">
  <% state_presenter = visible_state_presenter(@game_session) %>
  <% active_states_presenter = active_states_panel_presenter(@game_session) %>
  <header class="session-header">
    <div>
      <p class="eyebrow">RomeBots</p>
      <h1><%= @game_session.year_label %></h1>
    </div>
    <div class="session-meta">
      <span class="pill"><%= @game_session.status.humanize %></span>
      <span class="pill"><%= deck_progress_label(@game_session) %></span>
    </div>
  </header>

  <% if flash[:alert].present? %>
    <p class="flash-alert"><%= flash[:alert] %></p>
  <% end %>

  <section class="game-grid">
    <%= render Sessions::CurrentCardComponent.new(game_session: @game_session, card: @game_session.current_card) %>

    <div class="sidebar-column">
      <%= app_partial "sessions/state_panel", title: "State", state_presenter: state_presenter, panel_class: "state-panel" %>
      <%= app_partial "sessions/active_states_panel", active_states_presenter: active_states_presenter, panel_class: "active-states-panel" %>
      <%= app_partial "sessions/event_log" %>
    </div>
  </section>
</main>
